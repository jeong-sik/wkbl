# Cloudflare Tunnel (Zero Trust) token (required)
# - Zero Trust Dashboard > Networks > Tunnels > Create tunnel > Docker
CLOUDFLARE_TUNNEL_TOKEN=

# Build-time: how many years to backfill into data/wkbl.db inside the image.
WKBL_YEARS=5

# Optional: cache busting for static assets (default: auto from server start time).
WKBL_ASSET_VERSION=

# Optional: Cloudflare Web Analytics token (free).
CF_WEB_ANALYTICS_TOKEN=

